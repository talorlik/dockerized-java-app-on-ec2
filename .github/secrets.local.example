# .github/secrets.local - Loaded by .actrc as `--secret-file`.
#
# Maps to `${{ secrets.* }}` references inside workflows during local act
# runs. Real GitHub-hosted runners read from the repo/environment Secrets
# UI; this file is local-only and gitignored.
#
# Only secrets actually referenced by workflows are listed. If you add a new
# `${{ secrets.X }}` reference, append `X=` here.
#
# Cross-reference with Settings -> Secrets and variables -> Actions in the
# upstream repo to ensure the same names exist on both sides.

# IAM role for the DEPLOYMENT account. Trusted for OIDC via
# token.actions.githubusercontent.com on real CI; under act, set this to any
# placeholder string - the OIDC step is skipped via `if: env.ACT != 'true'`
# in infra-apply.yml, infra-destroy.yml, app-deploy.yml.
DEPLOYMENT_ROLE_ARN=arn:aws:iam::000000000000:role/github-role

# Cross-account assume-role into the DOMAIN account for Route53. Only
# referenced as TF_VAR_domain_account_route53_role_arn inside terraform
# plan/apply/destroy. Under act, terraform receives this from the env vars
# the workflow sets. Provide a real value if you intend to run a full plan
# locally; otherwise a placeholder is fine for fmt/validate-only flows.
DOMAIN_ROUTE53_ROLE_ARN=arn:aws:iam::000000000000:role/route53-dns-manager-role

# ACM certificate for java.talorlik.com (issued in DEPLOYMENT account,
# region-pinned to AWS_REGION).
ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:000000000000:certificate/00000000-0000-0000-0000-000000000000

GH_TOKEN=REPLACE
