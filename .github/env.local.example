# .github/env.local - Loaded by .actrc as `--env-file`.
#
# Real GitHub-hosted runners ignore this file. It only affects local `act`
# invocations from the repo root. Copy to `.github/env.local` (gitignored)
# and fill in real values.
#
# Purpose: provide static AWS credentials so the act runner can call AWS APIs
# without OIDC. Workflows that require OIDC are guarded with
# `if: ${{ env.ACT != 'true' }}` on their `aws-actions/configure-aws-credentials`
# step (see infra-apply.yml, infra-destroy.yml, app-deploy.yml). Under act we
# rely on the env-file below to satisfy the AWS SDK chain instead.
#
# Tip: use a short-lived session token from `aws sts get-session-token` or an
# IAM Identity Center role. Do NOT paste long-lived user keys.
ACT=true

# Required by AWS SDK.
AWS_ACCESS_KEY_ID=ASIA...REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_SESSION_TOKEN=REPLACE
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# AWS CLI v2 piping: catthehacker:full-22.04 ships `less`, but keep this set
# defensively to match the workflows' inline `AWS_PAGER=""`.
AWS_PAGER=

# Force testcontainers to skip the Ryuk reaper container under act
# (PID-namespace mismatch when reaching the host daemon via bind-mounted
# socket). Same value the backend job sets in ci.yml.
TESTCONTAINERS_RYUK_DISABLED=true

# Pin the docker daemon socket to the standard path. catthehacker:full-22.04
# already mounts it; setting DOCKER_HOST removes ambiguity in the
# docker-java discovery path.
DOCKER_HOST=unix:///var/run/docker.sock
