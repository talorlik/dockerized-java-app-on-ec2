# .github/vars.local - Loaded by .actrc as `--var-file`.
#
# Maps to `${{ vars.* }}` references inside workflows during local act runs.
# On real CI these come from Settings -> Secrets and variables -> Actions
# (Variables tab). This file is local-only and gitignored.
#
# Only vars actually referenced by workflows are listed.
LOCAL_AWS_PROFILE=REPLACE

AWS_REGION=us-east-1

# 12-digit AWS account IDs. DEPLOYMENT hosts the app, ALB, RDS, ECR, etc.
# DOMAIN hosts the talorlik.com Route53 hosted zone.
DEPLOYMENT_ACCOUNT_ID=000000000000
DOMAIN_ACCOUNT_ID=000000000000

# Hosted zone ID for talorlik.com in the DOMAIN account.
HOSTED_ZONE_ID=Z000000000000000000000
